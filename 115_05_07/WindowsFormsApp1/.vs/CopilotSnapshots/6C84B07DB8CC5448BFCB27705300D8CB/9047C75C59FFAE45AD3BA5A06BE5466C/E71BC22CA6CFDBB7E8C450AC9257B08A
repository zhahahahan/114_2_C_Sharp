using System;
using System.Windows.Forms;

namespace WindowsFormsApp1
{
    public partial class Form1 : Form
    {
        private decimal balance = 0;
        private decimal winnings = 0;
        private Random random = new Random();

        public Form1()
        {
            InitializeComponent();
        }

        private void buttonDeposit_Click(object sender, EventArgs e)
        {
            if (decimal.TryParse(textBoxDeposit.Text, out decimal depositAmount))
            {
                if (depositAmount > 0)
                {
                    balance += depositAmount;
                    UpdateBalanceLabel();
                    textBoxDeposit.Clear();
                    MessageBox.Show($"存入 NT${depositAmount:F2} 成功！", "存入確認");
                }
                else
                {
                    MessageBox.Show("請輸入正數金額", "輸入錯誤");
                }
            }
            else
            {
                MessageBox.Show("請輸入有效的金額", "輸入錯誤");
            }
        }

        private void buttonSpin_Click(object sender, EventArgs e)
        {
            if (balance == 0)
            {
                MessageBox.Show("餘額不足，請先存入金額", "餘額不足");
                return;
            }

            string betText = comboBoxBet.SelectedItem?.ToString() ?? "$1";
            if (!decimal.TryParse(betText.TrimStart('$'), out decimal betAmount))
            {
                betAmount = 1;
            }

            if (balance < betAmount)
            {
                MessageBox.Show($"餘額不足，請選擇較小的下注金額", "餘額不足");
                return;
            }

            balance -= betAmount;
            winnings = 0;

            // 模擬轉盤結果
            int result1 = random.Next(1, 4);  // 1=西瓜 2=葡萄 3=蘋果
            int result2 = random.Next(1, 4);
            int result3 = random.Next(1, 4);

            DisplayResult(result1, pictureBox1);
            DisplayResult(result2, pictureBox2);
            DisplayResult(result3, pictureBox3);

            // 計算獲勝
            if (result1 == result2 && result2 == result3)
            {
                winnings = betAmount * 10;  // 中獎 x10
            }
            else if (result1 == result2 || result2 == result3 || result1 == result3)
            {
                winnings = betAmount * 3;   // 中獎 x3
            }

            balance += winnings;
            UpdateBalanceLabel();
        }

        private void DisplayResult(int result, PictureBox pictureBox)
        {
            // 根據結果顯示相應的圖片
            pictureBox.BackColor = System.Drawing.Color.Khaki;
            switch (result)
            {
                case 1:
                    pictureBox.Text = "🍉";  // 西瓜
                    break;
                case 2:
                    pictureBox.Text = "🍇";  // 葡萄
                    break;
                case 3:
                    pictureBox.Text = "🍎";  // 蘋果
                    break;
            }
        }

        private void UpdateBalanceLabel()
        {
            labelBalance.Text = $"餘額：NT${balance:F2}";
            labelWinning.Text = $"本次獲得：NT${winnings:F2}";
        }

        private void buttonExit_Click(object sender, EventArgs e)
        {
            Application.Exit();
        }
    }
}
