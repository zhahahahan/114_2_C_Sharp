using System;

namespace Coin_Toss
{
    public class Coin
    {
        private Random rand = new Random();
        private string sideUp; // 儲存目前朝上的面
n        public Coin() // 建構子，設定初始值
        {
            sideUp = "Heads"; // 預設為正面朝上
        }
n        public void Toss()
        {
            int side = rand.Next(2);
            if (side == 0)
            {
                sideUp = "Heads";
            }
            else
            {
                sideUp = "Tails";
            }
        }
n        public string GetSideUp()
        {
            return sideUp;
        }
    }
}
